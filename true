local easeLinear = TweenInfo.new(0.4,  Enum.EasingStyle.Linear)

local function fadeIn()
	TweenService:Create(frame,       easeOut, {Position = UDim2.new(0.5, -CARD_W / 2, 0.5, -CARD_H / 2), BackgroundTransparency = 0}):Play()
	TweenService:Create(logo,        easeOut, {ImageTransparency = 0}):Play()
	TweenService:Create(spinArc,     easeOut, {BackgroundTransparency = 0}):Play()
	TweenService:Create(hubTitle,    easeOut, {TextTransparency = 0}):Play()
	TweenService:Create(hubSub,      easeOut, {TextTransparency = 0}):Play()
	TweenService:Create(closeBtn,    easeOut, {TextTransparency = 0}):Play()
	TweenService:Create(minimizeBtn, easeOut, {TextTransparency = 0}):Play()
	task.wait(0.45)
end

local function showProgress(pct, label)
	if label then
		statusLabel.Text = label
		TweenService:Create(statusLabel, easeOut, {TextTransparency = 0}):Play()
	end
	TweenService:Create(barBg, easeOut, {BackgroundTransparency = 0}):Play()
	TweenService:Create(bar, easeLinear, {Size = UDim2.new(pct, 0, 1, 0)}):Play()
end

-- Re-engineered FadeOut loop to fix choppy element drops
local function fadeOut()
	TweenService:Create(frame,       easeIn, {Position = UDim2.new(0.5, -CARD_W / 2, 0.45, -CARD_H / 2), BackgroundTransparency = 1}):Play()
	if stroke then TweenService:Create(stroke, easeIn, {Transparency = 1}):Play() end

	for _, child in pairs(frame:GetDescendants()) do
		if child:IsA("TextLabel") or child:IsA("TextButton") then
			TweenService:Create(child, easeIn, {TextTransparency = 1, BackgroundTransparency = 1}):Play()
		elseif child:IsA("ImageLabel") then
			TweenService:Create(child, easeIn, {ImageTransparency = 1, BackgroundTransparency = 1}):Play()
		elseif child:IsA("UIStroke") then
			TweenService:Create(child, easeIn, {Transparency = 1}):Play()
		elseif child:IsA("Frame") then
			TweenService:Create(child, easeIn, {BackgroundTransparency = 1}):Play()
		end
	end
	task.wait(0.35)
end

-- Minimize / restore
local minimized = false
local function toggleMinimize()
	minimized = not minimized
	local targetH = minimized and TOP_H or CARD_H
	TweenService:Create(frame, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Size = UDim2.new(0, CARD_W, 0, targetH)}):Play()
	minimizeBtn.Text = minimized and "+" or "-"
end
minimizeBtn.MouseButton1Click:Connect(toggleMinimize)

-- Drag
local dragging  = false
local dragStart = nil
local startPos  = nil

local dragBar = Instance.new("TextButton")
dragBar.Size = UDim2.new(1, -100, 0, TOP_H)
dragBar.Position = UDim2.new(0, 0, 0, 0)
dragBar.BackgroundTransparency = 1
dragBar.Text = ""
dragBar.AutoButtonColor = false
dragBar.ZIndex = 105
dragBar.Parent = frame

dragBar.InputBegan:Connect(function(input)
	local t = input.UserInputType
	if t ~= Enum.UserInputType.MouseButton1 and t ~= Enum.UserInputType.Touch then return end
	dragging  = true
	dragStart = input.Position
	startPos  = frame.Position
end)

dragBar.InputEnded:Connect(function(input)
	local t = input.UserInputType
	if t ~= Enum.UserInputType.MouseButton1 and t ~= Enum.UserInputType.Touch then return end
	dragging = false
end)

UserInputService.InputChanged:Connect(function(input)
	if not dragging then return end
	local t = input.UserInputType
	if t ~= Enum.UserInputType.MouseMovement and t ~= Enum.UserInputType.Touch then return end
	local delta = input.Position - dragStart
	frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end)

-- Loops
local spinning       = true
local rainbowObjects  = {}
local rainbowRunning = true

task.spawn(function()
	local angle = 0
	while spinning do
		angle = (angle + 4) % 360
		spinFrame.Rotation = angle
		task.wait(0.016)
	end
end)

task.spawn(function()
	local hue = 0
	while rainbowRunning do
		hue = (hue + 0.005) % 1
		local color = Color3.fromHSV(hue, 1, 1)
		for _, obj in ipairs(rainbowObjects) do
			if obj and obj.Parent then
				if obj:IsA("UIStroke") then
					obj.Color = color
				end
			end
		end
		task.wait(0.03)
	end
end)

local function runScript(gameEntry)
	spinning           = false
	rainbowRunning     = false
	closeBtn.Active    = false
	minimizeBtn.Active = false
	dragging           = false
	dragBar.Active     = false

	showProgress(0.25, "Loading " .. gameEntry.name .. "...")
	task.wait(0.3)
	showProgress(0.65, "Fetching script...")

	local success, err = pcall(function()
		loadstring(game:HttpGet(gameEntry.url))()
	end)

	if success then
		bar.BackgroundColor3 = THEME.SuccessColor
		showProgress(1, gameEntry.name .. " loaded!")
	else
		bar.BackgroundColor3 = THEME.ErrorColor
		showProgress(1, "Error loading script")
		warn("AetherHub error:", err)
	end

	task.wait(1.2)
	fadeOut()
	task.wait(0.35)
	screenGui:Destroy()
end

local function makeGameButton(gameEntry, index)
	local isCurrentGame = detectedGame and gameEntry.placeId == detectedGame.placeId
	local yPos = TOP_H + (index - 1) * (BTN_H + BTN_GAP) + 6

	local defaultBg = isCurrentGame and Color3.fromRGB(30, 48, 38) or THEME.Card
	local hoverBg = isCurrentGame and Color3.fromRGB(40, 64, 50) or THEME.CardHover

	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -24, 0, BTN_H)
	btn.Position = UDim2.new(0, 12, 0, yPos + 16)
	btn.BackgroundColor3 = defaultBg
	btn.BorderSizePixel = 0
	btn.Text = gameEntry.name
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.TextSize = 17
	btn.Font = Enum.Font.GothamBold
	btn.TextXAlignment = Enum.TextXAlignment.Center -- Centered the text perfectly
	btn.AutoButtonColor = false
	btn.BackgroundTransparency = 1
	btn.ZIndex = 106
	btn.Parent = frame

	-- Rainbow Line Outline Around Buttons
	local rainbowStroke = Instance.new("UIStroke")
	rainbowStroke.Thickness = 2
	rainbowStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	rainbowStroke.Transparency = 0.1
	rainbowStroke.Parent = btn
	table.insert(rainbowObjects, rainbowStroke)

	-- Current Game Marker Indicators
	if isCurrentGame then
		-- Left green bar indicator
		local currentIndicator = Instance.new("Frame")
		currentIndicator.Size = UDim2.new(0, 4, 1, -16)
		currentIndicator.Position = UDim2.new(0, 8, 0, 8)
		currentIndicator.BackgroundColor3 = THEME.CurrentGame
		currentIndicator.BorderSizePixel = 0
		currentIndicator.ZIndex = 107
		currentIndicator.Parent = btn

		local indicatorCorner = Instance.new("UICorner")
		indicatorCorner.CornerRadius = UDim.new(1, 0)
		indicatorCorner.Parent = currentIndicator

		-- Right side glowing text badge
		local badge = Instance.new("TextLabel")
		badge.Size = UDim2.new(0, 74, 0, 22)
		badge.Position = UDim2.new(1, -86, 0.5, -11)
		badge.BackgroundColor3 = THEME.CurrentGame
		badge.Text = "CURRENT"
		badge.TextColor3 = Color3.fromRGB(15, 30, 20)
		badge.TextSize = 10
		badge.Font = Enum.Font.GothamBold
		badge.ZIndex = 107
		badge.Parent = btn

		local badgeCorner = Instance.new("UICorner")
		badgeCorner.CornerRadius = UDim.new(0, 6)
		badgeCorner.Parent = badge
	end

	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 10)
	btnCorner.Parent = btn

	-- Hover effects: Glow only
	btn.MouseEnter:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = hoverBg}):Play()
		TweenService:Create(rainbowStroke, TweenInfo.new(0.15), {Thickness = 4.5}):Play()
	end)

	btn.MouseLeave:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = defaultBg}):Play()
		TweenService:Create(rainbowStroke, TweenInfo.new(0.2), {Thickness = 2}):Play()
	end)

	local popIn = TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
	task.delay(0.08 * index, function()
		TweenService:Create(btn, popIn, {Position = UDim2.new(0, 12, 0, yPos), BackgroundTransparency = 0}):Play()
	end)

	return btn
end

fadeIn()

local loaded = false

for i, gameEntry in ipairs(games) do
	local btn = makeGameButton(gameEntry, i)

	btn.MouseButton1Click:Connect(function()
		if loaded then return end
		loaded = true

		for _, child in pairs(frame:GetChildren()) do
			if child:IsA("TextButton") and child ~= closeBtn and child ~= minimizeBtn and child ~= dragBar then
				child.Active = false
			end
		end

		TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = THEME.CardClick}):Play()
		task.wait(0.15)
		runScript(gameEntry)
	end)
end

closeBtn.MouseButton1Click:Connect(function()
	if loaded then return end
	spinning       = false
	rainbowRunning = false
	fadeOut()
	task.wait(0.35)
	screenGui:Destroy()
end)
